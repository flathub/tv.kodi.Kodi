{
    "name": "game.libretro.pokemini",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.pokemini",
            "commit": "4b14434c1b5f9063a54365e2da6addb774520903"
        }
    ],
    "modules": [
        {
            "name": "libretro-pokemini",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app -f Makefile.libretro",
                "install -D -m 755 pokemini_libretro.so /app/lib/libretro/pokemini_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/libretro/pokemini",
                    "commit": "bb009b1379ad15f1514f20ca7cbf710b4af42b3e"
                }
            ]
        }
    ]
}
