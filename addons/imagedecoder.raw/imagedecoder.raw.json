{
    "name": "imagedecoder.raw",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/xbmc/imagedecoder.raw",
            "commit": "3dc5d53bb5d0fee0d698e5e6ca278c6b7e0196be"
        }
    ],
    "modules": [
        {
            "name": "libraw",
            "cleanup": [
                "/bin"
            ],
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "sources": [
                {
                    "type": "archive",
                    "url": "https://www.libraw.org/data/LibRaw-0.22.2.tar.gz",
                    "sha256": "de86b035655accff8d4010f1a221fdf50d353cb7b1422ba26f14a0db92612cfa",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 1709,
                        "url-template": "https://www.libraw.org/data/LibRaw-$version.tar.gz"
                    }
                },
                {
                    "type": "script",
                    "dest-filename": "autogen.sh",
                    "commands": [
                        "autoreconf -vfi"
                    ]
                }
            ]
        }
    ],
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ]
}
