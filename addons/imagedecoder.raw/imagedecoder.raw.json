{
    "name": "imagedecoder.raw",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/xbmc/imagedecoder.raw",
            "commit": "b0ce0ac32d0a35eebbd88176b5704a03404979ed"
        },
        {
            "type": "file",
            "path": "tv.kodi.Kodi.Addon.imagedecoder.raw.metainfo.xml"
        }
    ],
    "post-install": [
        "install -Dp -m 644 tv.kodi.Kodi.Addon.imagedecoder.raw.metainfo.xml --target-directory=${FLATPAK_DEST}/share/metainfo"
    ],
    "modules": [
        {
            "name": "libraw",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/LibRaw/LibRaw/archive/refs/tags/0.22.0.tar.gz",
                    "sha256": "5a11327a9cef2496d6a4335e8da30a1604460b6c545a30fe7588cf4c00a0fcae"
                },
                {
                    "type": "script",
                    "dest-filename": "autogen.sh",
                    "commands": [
                        "autoreconf -vfi"
                    ]
                }
            ]
        }
    ],
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DPACKAGE_ZIP=ON"
    ]
}
