{
    "name": "game.libretro.tyrquake",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.tyrquake",
            "commit": "d5a5283a13d82f50b5186e486620797a815a4d0d"
        }
    ],
    "modules": [
        {
            "name": "libretro-tyrquake",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app",
                "install -D -m 755 tyrquake_libretro.so /app/lib/libretro/tyrquake_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/libretro/tyrquake",
                    "commit": "e57bb11597e8a00380f30f2627d219da960cf69a"
                }
            ]
        }
    ]
}
