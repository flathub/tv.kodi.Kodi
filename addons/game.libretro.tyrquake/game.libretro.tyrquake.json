{
    "name": "game.libretro.tyrquake",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.tyrquake",
            "commit": "f2f4d8c1029d81b4b65f9426d464850d63b7838b"
        }
    ],
    "modules": [
        {
            "name": "libretro-tyrquake",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app",
                "install -D -m 755 tyrquake_libretro.so /app/lib/libretro/tyrquake_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/libretro/tyrquake/archive/bb7efdbd7371bdfd176d8228bdbd6b1a08b85ddd.tar.gz",
                    "sha256": "3a7f4d59575d57ddad9d6eca43c859c1b75a4b01a7f22a7ac6362b59dc3f658b"
                }
            ]
        }
    ]
}
