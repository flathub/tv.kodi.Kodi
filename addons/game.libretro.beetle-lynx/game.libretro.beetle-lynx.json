{
    "name": "game.libretro.beetle-lynx",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.beetle-lynx",
            "commit": "9238e6b33fd8bb57aa1964464b5fa9315d04a14d"
        }
    ],
    "modules": [
        {
            "name": "libretro-beetle-lynx",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app",
                "install -D -m 755 mednafen_lynx_libretro.so /app/lib/libretro/mednafen_lynx_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/libretro/beetle-lynx-libretro/archive/fcdefcfb3c11d6d2e71be076a5d3df2e88ab73ed.tar.gz",
                    "sha256": "3dd45a6f6585c444a415cb097996c572467754748e7163eca466d89b31bd8b37"
                }
            ]
        }
    ]
}
