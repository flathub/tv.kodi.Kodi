{
    "name": "imagedecoder.mpo",
    "buildsystem": "cmake-ninja",
    "builddir": true,
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/xbmc/imagedecoder.mpo",
            "commit": "dc89b40915798cacd29b2a8360c9f006159120c5"
        },
        {
            "type": "file",
            "path": "../../tools/gen-addon-metainfo.sh"
        }
    ],
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DPACKAGE_ZIP=ON",
        "-DCMAKE_PREFIX_PATH=/app",
        "-DCMAKE_INSTALL_PREFIX=/app/lib/kodi/addons"
    ],
    "post-install": [
        "bash $FLATPAK_BUILDER_BUILDDIR/gen-addon-metainfo.sh imagedecoder.mpo"
    ]
}
