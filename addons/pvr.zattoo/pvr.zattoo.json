{
    "name": "pvr.zattoo",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/rbuehlma/pvr.zattoo",
            "commit": "e315b3d8f48847b1a9580a4fcd67c5aaf114245a"
        },
        {
            "type": "file",
            "path": "tv.kodi.Kodi.Addon.pvr.zattoo.metainfo.xml"
        }
