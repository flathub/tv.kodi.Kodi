{
    "name": "audioencoder.vorbis",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/xbmc/audioencoder.vorbis",
            "commit": "8e8ad4ac2c2cbde755f45259324d883af73dce4e"
        },
        {
            "type": "file",
            "path": "tv.kodi.Kodi.Addon.audioencoder.vorbis.metainfo.xml"
        }
    ],
    "post-install": [
        "install -Dp -m 644 tv.kodi.Kodi.Addon.audioencoder.vorbis.metainfo.xml --target-directory=${FLATPAK_DEST}/share/metainfo"
    ],
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DPACKAGE_ZIP=ON"
    ]
}
