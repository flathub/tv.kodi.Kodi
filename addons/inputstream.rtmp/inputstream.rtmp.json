{
    "name": "inputstream.rtmp",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/xbmc/inputstream.rtmp",
            "commit": "1b995db747b3f8671e04377e069a7b9d9260944d"
        },
        {
            "type": "file",
            "path": "../../tools/gen-addon-metainfo.sh"
        }
    ],
    "modules": [
        {
            "name": "rtmpdump",
            "buildsystem": "simple",
            "build-commands": [
                "sed -e 's/^CRYPTO=OPENSSL/CRYPTO=GNUTLS/' -i librtmp/Makefile",
                "sed -e 's|usr/local|app|' -i librtmp/Makefile",
                "make -C librtmp",
                "make -C librtmp install PREFIX=/app"
            ],
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/mirror/rtmpdump/archive/6f6bb1353fc84f4cc37138baa99f586750028a01.tar.gz",
                    "sha256": "5d68d69710be21e86e766753d2bd25cb2ad1c853b0bc80ebe6b49a6cc507bfc0"
                }
            ]
        }
    ],
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DPACKAGE_ZIP=ON",
        "-DCMAKE_PREFIX_PATH=/app",
        "-DCMAKE_INSTALL_PREFIX=/app/lib/kodi/addons"
    ],
    "post-install": [
        "bash $FLATPAK_BUILDER_BUILDDIR/gen-addon-metainfo.sh inputstream.rtmp"
    ]
}
