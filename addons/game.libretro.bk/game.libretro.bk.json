{
    "name": "game.libretro.bk",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.bk",
            "commit": "7415d844af40f9744d9725b5705ad1a7b8a9b28a"
        }
    ],
    "modules": [
        {
            "name": "libretro-bk",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app -f Makefile.libretro",
                "install -D -m 755 bk_libretro.so /app/lib/libretro/bk_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/libretro/bk-emulator/archive/fe64da42ee463c1b2f4d0566e4d0f7a9667506f6.tar.gz",
                    "sha256": "bccd1788516c952001d362f8661d7a88539dcf2bf45e25b0e25584ff4e86721b"
                }
            ]
        }
    ]
}
