{
    "name": "game.libretro.bk",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DPACKAGE_ZIP=ON",
        "-DCMAKE_PREFIX_PATH=/app",
        "-DCMAKE_INSTALL_PREFIX=/app/lib/kodi/addons"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.bk",
            "commit": "bdd33b068b58fd634722508f0655543f8cb6d6bc"
        },
        {
            "type": "file",
            "path": "../../tools/gen-addon-metainfo.sh"
        }
    ],
    "modules": [
        {
            "name": "libretro-bk",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app -f Makefile.libretro",
                "install -D -m 755 bk_libretro.so /app/lib/libretro/bk_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/libretro/bk-emulator",
                    "commit": "fe64da42ee463c1b2f4d0566e4d0f7a9667506f6"
                }
            ]
        }
    ],
    "post-install": [
        "bash $FLATPAK_BUILDER_BUILDDIR/gen-addon-metainfo.sh game.libretro.bk"
    ]
}
