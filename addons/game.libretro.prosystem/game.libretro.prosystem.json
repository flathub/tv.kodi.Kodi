{
    "name": "game.libretro.prosystem",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.prosystem",
            "commit": "51e81e432c508028c1004f95bfc9523b4d58f260"
        }
    ],
    "modules": [
        {
            "name": "libretro-prosystem",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app",
                "install -D -m 755 prosystem_libretro.so /app/lib/libretro/prosystem_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/libretro/prosystem-libretro",
                    "commit": "3f465db9c82fc6764cd90c53fc66eb630e0b3710"
                }
            ]
        }
    ]
}
