{
    "name": "game.libretro.virtualjaguar",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.virtualjaguar",
            "commit": "b9579f841f0299bc685a31834a1ddaf440807f4a"
        }
    ],
    "modules": [
        {
            "name": "libretro-virtualjaguar",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app",
                "install -D -m 755 virtualjaguar_libretro.so /app/lib/libretro/virtualjaguar_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/libretro/virtualjaguar-libretro",
                    "commit": "18828045f76a803206ebffc9b8d57842287b7552"
                }
            ]
        }
    ]
}
