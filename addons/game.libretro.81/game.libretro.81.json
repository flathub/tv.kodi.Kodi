{
    "name": "game.libretro.81",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.81",
            "commit": "2f3cdc89755317f076db701872d169648e57e2c1"
        }
    ],
    "modules": [
        {
            "name": "libretro-81",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app -f Makefile.libretro",
                "install -D -m 755 81_libretro.so /app/lib/libretro/81_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/libretro/81-libretro/archive/fa7094910d040baa5fd8b11dbf6a1a618330ecd9.tar.gz",
                    "sha256": "fe8645529ce2140d29d2cad65dc2144bb3a41d858fd23345f85e412081d26aad"
                }
            ]
        }
    ]
}
