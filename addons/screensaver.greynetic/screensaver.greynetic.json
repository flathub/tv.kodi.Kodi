{
    "name": "screensaver.greynetic",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/xbmc/screensaver.greynetic",
            "commit": "7a00c8a994fe3f8b7f93331db0ee36ecb5c45bea"
        },
        {
            "type": "file",
            "path": "tv.kodi.Kodi.Addon.screensaver.greynetic.metainfo.xml"
        }
    ],
    "post-install": [
        "install -Dp -m 644 tv.kodi.Kodi.Addon.screensaver.greynetic.metainfo.xml --target-directory=${FLATPAK_DEST}/share/metainfo"
