{
    "name": "game.libretro.mrboom",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DPACKAGE_ZIP=ON"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.mrboom",
            "commit": "6c20a884fedd80fe50c24f9c5d97d08b7d302cd0"
        },
        {
            "type": "file",
            "path": "tv.kodi.Kodi.Addon.game.libretro.mrboom.metainfo.xml"
        }
    ],
    "post-install": [
        "install -Dp -m 644 tv.kodi.Kodi.Addon.game.libretro.mrboom.metainfo.xml --target-directory=${FLATPAK_DEST}/share/metainfo"
    ],
    "modules": [
        {
            "name": "mrboom",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j PREFIX=/app platform=unix",
                "install -D -m 755 mrboom_libretro.so /app/lib/libretro/mrboom_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/kodi-game/mrboom-libretro/archive/0e52349c674860190397075ba3993efe5b65b887.tar.gz",
                    "sha256": "89cd6c6d0f94b9e59ccc57547e401e41223f2413c88bcf1c65e791866e567dc9"
                }
            ]
        }
    ]
}
