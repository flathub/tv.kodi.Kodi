{
    "name": "screensaver.pyro",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/xbmc/screensaver.pyro",
            "commit": "94c7bc9d25aa5317a0dd91ef377dbdc547f8f32b"
        },
        {
            "type": "file",
            "path": "tv.kodi.Kodi.Addon.screensaver.pyro.metainfo.xml"
        }
    ],
    "post-install": [
        "install -Dp -m 644 tv.kodi.Kodi.Addon.screensaver.pyro.metainfo.xml --target-directory=${FLATPAK_DEST}/share/metainfo"
