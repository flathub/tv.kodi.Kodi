{
    "name": "pvr.mythtv",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/janbar/pvr.mythtv",
            "commit": "883f91737d4e75cf0aa5cdb22970190dee05e722"
        },
        {
            "type": "file",
            "path": "tv.kodi.Kodi.Addon.pvr.mythtv.metainfo.xml"
        }
    ],
    "post-install": [
        "install -Dp -m 644 tv.kodi.Kodi.Addon.pvr.mythtv.metainfo.xml --target-directory=${FLATPAK_DEST}/share/metainfo"
    ],
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DPACKAGE_ZIP=ON"
    ]
}
