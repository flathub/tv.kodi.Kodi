{
    "name": "pvr.freebox",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/aassif/pvr.freebox",
            "commit": "196783631b429883102c4ede56f96daf80d5a8b4"
        },
        {
            "type": "file",
            "path": "tv.kodi.Kodi.Addon.pvr.freebox.metainfo.xml"
        }
