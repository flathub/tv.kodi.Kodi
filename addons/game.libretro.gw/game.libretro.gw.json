{
    "name": "game.libretro.gw",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.gw",
            "commit": "e4afdd4062dc496029b1b5447cc775eee42c8106"
        }
    ],
    "modules": [
        {
            "name": "libretro-gw",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app -f Makefile.libretro",
                "install -D -m 755 gw_libretro.so /app/lib/libretro/gw_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/libretro/gw-libretro",
                    "commit": "91d599b951e7bfe7e040347f58667cba20074adc"
                }
            ]
        }
    ]
}
