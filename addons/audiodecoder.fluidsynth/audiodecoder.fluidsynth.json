{
    "name": "audiodecoder.fluidsynth",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DPACKAGE_ZIP=ON",
        "-DCMAKE_PREFIX_PATH=/app",
        "-DCMAKE_INSTALL_PREFIX=/app/lib/kodi/addons"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/xbmc/audiodecoder.fluidsynth",
            "commit": "7160ac6b7a4db7029b8ec2bae08717c3be0cedd7"
        },
        {
            "type": "file",
            "path": "../../tools/gen-addon-metainfo.sh"
        }
    ],
    "modules": [
        "../../shared-modules/linux-audio/fluidsynth2.json"
    ],
    "post-install": [
        "bash $FLATPAK_BUILDER_BUILDDIR/gen-addon-metainfo.sh audiodecoder.fluidsynth"
    ]
}
