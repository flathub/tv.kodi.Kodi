{
    "name": "game.libretro.2048",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.2048",
            "commit": "bcc433552cfc066a093be5b80124c0e755974083"
        }
    ],
    "modules": [
        {
            "name": "2048",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -f Makefile.libretro PREFIX=/app platform=unix",
                "install -D -m 755 2048_libretro.so /app/lib/libretro/2048_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/libretro/libretro-2048",
                    "commit": "c90437d3c3913999624deca3fb55ecfa632b72c4"
                }
            ]
        }
    ],
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ]
}
