{
    "name": "game.libretro.2048",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.2048",
            "commit": "8844f975d7946d720eaf0c9f2486e650b7a8428c"
        },
        {
            "type": "file",
            "path": "tv.kodi.Kodi.Addon.game.libretro._2048.metainfo.xml"
        }
    ],
    "post-install": [
        "install -Dp -m 644 tv.kodi.Kodi.Addon.game.libretro._2048.metainfo.xml --target-directory=${FLATPAK_DEST}/share/metainfo"
    ],
    "modules": [
        {
            "name": "2048",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -f Makefile.libretro PREFIX=/app platform=unix",
                "install -D -m 755 2048_libretro.so /app/lib/libretro/2048_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/libretro/libretro-2048/archive/e70c3f82d2b861c64943aaff7fcc29a63013997d.tar.gz",
                    "sha256": "07d51892d173d85715d0cddd5963c50c2308e2d92401c4e79208544bc95f6f19"
                }
            ]
        }
    ],
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DPACKAGE_ZIP=ON"
    ]
}
