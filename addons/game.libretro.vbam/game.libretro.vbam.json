{
    "name": "game.libretro.vbam",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.vbam",
            "commit": "89781679d04d1e2b406963288579795d92faed89"
        }
    ],
    "modules": [
        {
            "name": "libretro-vbam",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app -C src/libretro/",
                "install -D -m 755 src/libretro/vbam_libretro.so /app/lib/libretro/vbam_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/visualboyadvance-m/visualboyadvance-m",
                    "commit": "e2c073378c8d31cec691faba33912f6a709f1483"
                }
            ]
        }
    ]
}
