{
    "name": "game.libretro.vbam",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.vbam",
            "commit": "89781679d04d1e2b406963288579795d92faed89"
        }
    ],
    "modules": [
        {
            "name": "libretro-vbam",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "cmake -B build -G Ninja -DCMAKE_BUILD_TYPE=Release -DENABLE_LIBRETRO=ON -DENABLE_WX=OFF -DENABLE_SDL=OFF -DENABLE_LINK=OFF -DBUILD_TESTING=OFF -DENABLE_LTO=OFF",
                "cmake --build build --target vbam_libretro -j$FLATPAK_BUILDER_N_JOBS",
                "install -D -m 755 build/vbam_libretro.so /app/lib/libretro/vbam_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/visualboyadvance-m/visualboyadvance-m",
                    "commit": "55bbb4f932d3f50d4c284490308e4dbac9e51743"
                }
            ]
        }
    ]
}
