{
    "name": "game.libretro.beetle-gba",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.beetle-gba",
            "commit": "b3fcd062794a830ea076043949e1aed3db915724"
        }
    ],
    "modules": [
        {
            "name": "libretro-beetle-gba",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app",
                "install -D -m 755 mednafen_gba_libretro.so /app/lib/libretro/mednafen_gba_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/libretro/beetle-gba-libretro",
                    "commit": "145d4884ad246e3c16765f6d69decb2a4359b6ae"
                }
            ]
        }
    ]
}
