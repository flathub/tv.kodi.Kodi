{
    "name": "pvr.teleboy",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/rbuehlma/pvr.teleboy",
            "commit": "bd390ed295c88bb92a6d29be154a0a6a9b6fe9b8"
        },
        {
            "type": "file",
            "path": "tv.kodi.Kodi.Addon.pvr.teleboy.metainfo.xml"
        }
    ],
    "post-install": [
        "install -Dp -m 644 tv.kodi.Kodi.Addon.pvr.teleboy.metainfo.xml --target-directory=${FLATPAK_DEST}/share/metainfo"
    ],
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DPACKAGE_ZIP=ON"
    ]
}
