{
    "name": "game.libretro.prboom",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.prboom",
            "commit": "476dc3a4b94505bbe50c904de36f0cfe5a7d70aa"
        }
    ],
    "modules": [
        {
            "name": "libretro-prboom",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app platform=unix",
                "install -D -m 755 prboom_libretro.so /app/lib/libretro/prboom_libretro.so",
                "install -D -m 644 prboom.wad /app/share/retroarch/system/prboom.wad"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/libretro/libretro-prboom",
                    "commit": "648223372e24773821a2041e0c39728f723badf4"
                }
            ]
        }
    ]
}
