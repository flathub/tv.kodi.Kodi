{
    "name": "screensaver.cpblobs",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/xbmc/screensaver.cpblobs",
            "commit": "ac86ab042f9cacc00e6512cb8c71162e5bad28b2"
        },
        {
            "type": "file",
            "path": "../../tools/gen-addon-metainfo.sh"
        }
    ],
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DPACKAGE_ZIP=ON",
        "-DCMAKE_PREFIX_PATH=/app",
        "-DCMAKE_INSTALL_PREFIX=/app/lib/kodi/addons"
    ],
    "post-install": [
        "bash $FLATPAK_BUILDER_BUILDDIR/gen-addon-metainfo.sh screensaver.cpblobs"
    ]
}
