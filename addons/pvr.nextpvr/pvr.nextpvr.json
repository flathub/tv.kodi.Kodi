{
    "name": "pvr.nextpvr",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-pvr/pvr.nextpvr",
            "commit": "b868201bcd06134f48d9ee4c5ee9b1bdf2e4c842"
        },
        {
            "type": "file",
            "path": "tv.kodi.Kodi.Addon.pvr.nextpvr.metainfo.xml"
        }
    ],
    "post-install": [
        "install -Dp -m 644 tv.kodi.Kodi.Addon.pvr.nextpvr.metainfo.xml --target-directory=${FLATPAK_DEST}/share/metainfo"
    ],
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DPACKAGE_ZIP=ON"
    ]
}
