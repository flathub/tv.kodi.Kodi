{
    "name": "game.libretro.beetle-wswan",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.beetle-wswan",
            "commit": "82b22c4848f346ac0e6f6a8cebde7c0ad961aa0f"
        }
    ],
    "modules": [
        {
            "name": "libretro-beetle-wswan",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app",
                "install -D -m 755 mednafen_wswan_libretro.so /app/lib/libretro/mednafen_wswan_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/libretro/beetle-wswan-libretro",
                    "commit": "da6d0d9acb8d4e9bd6725ab44225a275325d8352"
                }
            ]
        }
    ]
}
