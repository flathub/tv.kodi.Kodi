{
    "name": "game.libretro.quicknes",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.quicknes",
            "commit": "eaacbc10099374f4731ae765a812773f54b548b0"
        }
    ],
    "modules": [
        {
            "name": "libretro-quicknes",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app",
                "install -D -m 755 quicknes_libretro.so /app/lib/libretro/quicknes_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/libretro/QuickNES_Core",
                    "commit": "a0ec494c417f365c578f3dacadb04383e4a99ade"
                }
            ]
        }
    ]
}
