{
    "name": "game.libretro.beetle-supergrafx",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.beetle-supergrafx",
            "commit": "adc7b817bc2558cfaa232116ff6b6eb687029d04"
        }
    ],
    "modules": [
        {
            "name": "libretro-beetle-supergrafx",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app",
                "install -D -m 755 mednafen_supergrafx_libretro.so /app/lib/libretro/mednafen_supergrafx_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/libretro/beetle-supergrafx-libretro",
                    "commit": "3c6fcd3deded54ebecd69408f108407ac03d11b5"
                }
            ]
        }
    ]
}
