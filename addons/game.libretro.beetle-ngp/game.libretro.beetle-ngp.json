{
    "name": "game.libretro.beetle-ngp",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.beetle-ngp",
            "commit": "b0d3f5edfffd7b59dc61cef85a1204962c628eed"
        }
    ],
    "modules": [
        {
            "name": "libretro-beetle-ngp",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app",
                "install -D -m 755 mednafen_ngp_libretro.so /app/lib/libretro/mednafen_ngp_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/libretro/beetle-ngp-libretro/archive/0c81ce8991a47aac5d0a7d1ae53de75bc7ddf847.tar.gz",
                    "sha256": "8e2ad41c25bd7cf7ebbd4daf0676029acf646f470fc09f30dd45c80d7515d436"
                }
            ]
        }
    ]
}
