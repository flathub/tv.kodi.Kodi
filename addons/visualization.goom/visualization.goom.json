{
    "name": "visualization.goom",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/xbmc/visualization.goom",
            "commit": "9449d5834b94e757fa610a1e65de59d33f47091d"
        },
        {
            "type": "file",
            "path": "../../tools/gen-addon-metainfo.sh"
        }
    ],
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DPACKAGE_ZIP=ON",
        "-DCMAKE_PREFIX_PATH=/app",
        "-DCMAKE_INSTALL_PREFIX=/app/lib/kodi/addons"
    ],
    "post-install": [
        "bash $FLATPAK_BUILDER_BUILDDIR/gen-addon-metainfo.sh visualization.goom"
    ]
}
