{
    "name": "game.libretro.handy",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.handy",
            "commit": "907e7d3e9f85b1dd0cd9b48b44e2a309c8e8b0d4"
        }
    ],
    "modules": [
        {
            "name": "libretro-handy",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app",
                "install -D -m 755 handy_libretro.so /app/lib/libretro/handy_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/libretro/libretro-handy",
                    "commit": "bc55d462f0b2d6b073ea93dc552ebd73cec60fd1"
                }
            ]
        }
    ]
}
