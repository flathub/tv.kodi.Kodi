{
    "name": "game.libretro.handy",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.handy",
            "commit": "264f3ce86474ec83ba58e9cfd6d0b33957cd2253"
        }
    ],
    "modules": [
        {
            "name": "libretro-handy",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app",
                "install -D -m 755 handy_libretro.so /app/lib/libretro/handy_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/libretro/libretro-handy/archive/bc55d462f0b2d6b073ea93dc552ebd73cec60fd1.tar.gz",
                    "sha256": "65ad333df22aab7f3c8156c21ffd0b8da1ef09c7a7f1775df964b89986aa7324"
                }
            ]
        }
    ]
}
