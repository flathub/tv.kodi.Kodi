{
    "name": "audioencoder.flac",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/xbmc/audioencoder.flac",
            "commit": "75046700f45e13412b8d4defd416e6e9abebe7f5"
        },
        {
            "type": "file",
            "path": "tv.kodi.Kodi.Addon.audioencoder.flac.metainfo.xml"
        }
    ],
    "post-install": [
        "install -Dp -m 644 tv.kodi.Kodi.Addon.audioencoder.flac.metainfo.xml --target-directory=${FLATPAK_DEST}/share/metainfo"
