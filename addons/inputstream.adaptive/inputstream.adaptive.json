{
    "name": "inputstream.adaptive",
    "buildsystem": "cmake-ninja",
    "config-opts": [
        "-DBUILD_TESTING=OFF",
        "-DENABLE_INTERNAL_BENTO4=ON",
        "-DBENTO4_URL=bento4.tar.gz",
        "-DCMAKE_BUILD_TYPE=Release",
        "-DPACKAGE_ZIP=ON"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/xbmc/inputstream.adaptive",
            "commit": "097a80fa07f04efa9b3687887b4fdf008a076f14"
        },
        {
            "type": "file",
            "url": "https://github.com/xbmc/Bento4/archive/refs/tags/1.6.0-641-5-Piers.tar.gz",
            "sha256": "84a930e523553d638de7b2c66176e25c5910c65b906a06fb7211530df8edfc1f",
            "dest-filename": "bento4.tar.gz"
        },
        {
            "type": "file",
            "path": "tv.kodi.Kodi.Addon.inputstream.adaptive.metainfo.xml"
        }
    ],
    "post-install": [
        "install -Dp -m 644 tv.kodi.Kodi.Addon.inputstream.adaptive.metainfo.xml --target-directory=${FLATPAK_DEST}/share/metainfo"
    ],
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    }
}
