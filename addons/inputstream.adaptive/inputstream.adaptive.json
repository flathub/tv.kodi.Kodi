{
    "name": "inputstream.adaptive",
    "buildsystem": "cmake-ninja",
    "config-opts": [
        "-DBUILD_TESTING=OFF",
        "-DENABLE_INTERNAL_BENTO4=ON",
        "-DBENTO4_URL=bento4.tar.gz",
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/xbmc/inputstream.adaptive",
            "commit": "c531e079ad13f92631d9304a682af6e650da0d58"
        },
        {
            "type": "file",
            "url": "https://github.com/xbmc/Bento4/archive/refs/tags/1.6.0-641-6-Piers.tar.gz",
            "sha256": "cb5006cd30889238760556e6148f69be34fef4dc48e8d895a9822f805504a5c0",
            "dest-filename": "bento4.tar.gz",
            "x-checker-data": {
                "type": "json",
                "url": "https://api.github.com/repos/xbmc/Bento4/tags?per_page=100",
                "version-query": "[.[] | select(.name | endswith(\"-Piers\"))] | sort_by([.name | scan(\"[0-9]+\") | tonumber]) | last | .name | rtrimstr(\"-Piers\")",
                "url-query": "\"https://github.com/xbmc/Bento4/archive/refs/tags/\" + $version + \"-Piers.tar.gz\""
            }
        }
    ],
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    }
}
