{
    "name": "screensavers.rsxs",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/xbmc/screensavers.rsxs",
            "commit": "de1ed48671271a956fc374ac181a4afec1b8bb09"
        },
        {
            "type": "file",
            "path": "tv.kodi.Kodi.Addon.screensaver.rsxs.metainfo.xml"
        }
    ],
    "post-install": [
        "install -Dp -m 644 tv.kodi.Kodi.Addon.screensaver.rsxs.metainfo.xml --target-directory=${FLATPAK_DEST}/share/metainfo"
