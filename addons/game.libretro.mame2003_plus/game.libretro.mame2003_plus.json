{
    "name": "game.libretro.mame2003_plus",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.mame2003_plus",
            "commit": "66571eb3b1233ecde33c423223791d31f69893f3"
        }
    ],
    "modules": [
        {
            "name": "libretro-mame2003_plus",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app ARCH= CC=cc NATIVE_CC=cc LD=cc",
                "install -D -m 755 mame2003_plus_libretro.so /app/lib/libretro/mame2003_plus_libretro.so",
                "install -D -m 644 metadata/mame2003-plus.xml /app/share/libretro-database/mame2003-plus/mame2003-plus.xml",
                "mkdir -p /app/share/retroarch/system/mame2003-plus",
                "cp -R metadata/artwork /app/share/retroarch/system/mame2003-plus/",
                "install -m 644 metadata/cheat.dat metadata/hiscore.dat metadata/history.dat /app/share/retroarch/system/mame2003-plus/"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/libretro/mame2003-plus-libretro",
                    "commit": "5373e38e1091eb28f075513ecdc2575bafc8a5e3"
                }
            ]
        }
    ]
}
