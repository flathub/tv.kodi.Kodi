{
    "name": "pvr.waipu",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/flubshi/pvr.waipu",
            "commit": "9dfa6af1f8d1198f6dce522b9c13099f0354381b"
        },
        {
            "type": "file",
            "path": "tv.kodi.Kodi.Addon.pvr.waipu.metainfo.xml"
        }
    ],
    "post-install": [
        "install -Dp -m 644 tv.kodi.Kodi.Addon.pvr.waipu.metainfo.xml --target-directory=${FLATPAK_DEST}/share/metainfo"
