    "post-install": [
        "install -Dp -m 644 ${FLATPAK_BUILDER_BUILDDIR}/pvr.waipu/LICENSE.txt ${FLATPAK_DEST}/share/licenses/tv.kodi.Kodi/pvr.waipu/LICENSE.txt"
    ]
