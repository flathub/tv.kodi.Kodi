{
    "name": "pvr.waipu",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/flubshi/pvr.waipu",
            "commit": "c8ad059c27bd995198aaf1b3e0cf5fa1e7beb1d1"
        },
        {
            "type": "file",
            "path": "tv.kodi.Kodi.Addon.pvr.waipu.metainfo.xml"
        }
    ],
    "post-install": [
        "install -Dp -m 644 tv.kodi.Kodi.Addon.pvr.waipu.metainfo.xml --target-directory=${FLATPAK_DEST}/share/metainfo"
    ],
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DPACKAGE_ZIP=ON"
    ]
}
