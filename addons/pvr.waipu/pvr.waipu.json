{
    "name": "pvr.waipu",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/flubshi/pvr.waipu",
            "commit": "4a34641ab278f23571f7addfacc34704e0835600"
        }
    ],
    "build-options": {
