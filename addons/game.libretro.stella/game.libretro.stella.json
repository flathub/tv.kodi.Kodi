{
    "name": "game.libretro.stella",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.stella",
            "commit": "3d590cd955e61e43918186b44b96707de46caca7"
        }
    ],
    "modules": [
        {
            "name": "libretro-stella",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app -C src/os/libretro -f Makefile",
                "install -D -m 755 src/os/libretro/stella_libretro.so /app/lib/libretro/stella_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/stella-emu/stella/archive/01fc3ffe81f20c0d1eebfbb720ef58dca2af9a12.tar.gz",
                    "sha256": "529ef737752709c0fd1e1bf9eafd1e8fe45ef38690f5544e582cfac3c357eb53"
                }
            ]
        }
    ]
}
