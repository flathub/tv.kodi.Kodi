{
    "name": "game.libretro.stella",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.stella",
            "commit": "d5c57b2237874598ff87fe6419fcb4635acff76f"
        }
    ],
    "modules": [
        {
            "name": "libretro-stella",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app -C src/os/libretro -f Makefile",
                "install -D -m 755 src/os/libretro/stella_libretro.so /app/lib/libretro/stella_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/stella-emu/stella",
                    "commit": "eb656bb8521b00fdb0b40bec8d7745bdd2dfa947"
                }
            ]
        }
    ]
}
