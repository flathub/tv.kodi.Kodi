{
    "name": "game.libretro.stella",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DPACKAGE_ZIP=ON",
        "-DCMAKE_PREFIX_PATH=/app",
        "-DCMAKE_INSTALL_PREFIX=/app/lib/kodi/addons"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.stella",
            "commit": "b29a9894e286e6630de43e24bd160413ebce86cf"
        },
        {
            "type": "file",
            "path": "../../tools/gen-addon-metainfo.sh"
        }
    ],
    "modules": [
        {
            "name": "libretro-stella",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app -C src/os/libretro -f Makefile",
                "install -D -m 755 src/os/libretro/stella_libretro.so /app/lib/libretro/stella_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/stella-emu/stella",
                    "commit": "90d01ecb309b9c3317ca762078d4df40681e111b"
                }
            ]
        }
    ],
    "post-install": [
        "bash $FLATPAK_BUILDER_BUILDDIR/gen-addon-metainfo.sh game.libretro.stella"
    ]
}
