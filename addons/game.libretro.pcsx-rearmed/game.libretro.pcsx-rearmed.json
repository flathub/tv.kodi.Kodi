{
    "name": "game.libretro.pcsx-rearmed",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DPACKAGE_ZIP=ON",
        "-DCMAKE_PREFIX_PATH=/app",
        "-DCMAKE_INSTALL_PREFIX=/app/lib/kodi/addons"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.pcsx-rearmed",
            "commit": "850e3db7994b967faf4869d07a03db9fae991d5a"
        },
        {
            "type": "file",
            "path": "../../tools/gen-addon-metainfo.sh"
        }
    ],
    "modules": [
        {
            "name": "libretro-pcsx-rearmed",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0",
                "arch": {
                    "x86_64": {
                        "env": {
                            "ARCH_FLAGS": "platform=unix DYNAREC=none"
                        }
                    },
                    "aarch64": {
                        "env": {
                            "ARCH_FLAGS": "platform=unix DYNAREC=ari64"
                        }
                    }
                }
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app $ARCH_FLAGS -f Makefile.libretro",
                "install -D -m 755 pcsx_rearmed_libretro.so /app/lib/libretro/pcsx_rearmed_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/libretro/pcsx_rearmed",
                    "commit": "050981b6eeb715f142854f57c68086f62921f027"
                }
            ]
        }
    ],
    "post-install": [
        "bash $FLATPAK_BUILDER_BUILDDIR/gen-addon-metainfo.sh game.libretro.pcsx-rearmed"
    ]
}
