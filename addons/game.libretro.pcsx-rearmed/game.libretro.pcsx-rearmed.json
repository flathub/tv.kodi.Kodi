{
    "name": "game.libretro.pcsx-rearmed",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.pcsx-rearmed",
            "commit": "af400a7e20b15d340429a6b1ef942e1cdcfb291f"
        }
    ],
    "modules": [
        {
            "name": "libretro-pcsx-rearmed",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0",
                "arch": {
                    "x86_64": {
                        "env": {
                            "ARCH_FLAGS": "platform=unix DYNAREC=none"
                        }
                    },
                    "aarch64": {
                        "env": {
                            "ARCH_FLAGS": "platform=unix DYNAREC=ari64"
                        }
                    }
                }
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app $ARCH_FLAGS -f Makefile.libretro",
                "install -D -m 755 pcsx_rearmed_libretro.so /app/lib/libretro/pcsx_rearmed_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/libretro/pcsx_rearmed/archive/a97efbb0646dd7766bd66fe9e93118206edec36a.tar.gz",
                    "sha256": "ca8bbe47b4e4720d62c3ec9f42ba31e60d3aa3e15643dbc7620fffbb6a1bf80d"
                }
            ]
        }
    ]
}
