{
    "name": "visualization.pictureit",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/xbmc/visualization.pictureit",
            "commit": "f8979847fd53908d59fa42f7b4f2d3fff94ad115"
        },
        {
            "type": "file",
            "path": "tv.kodi.Kodi.Addon.visualization.pictureit.metainfo.xml"
        }
