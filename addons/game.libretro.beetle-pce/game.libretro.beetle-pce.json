{
    "name": "game.libretro.beetle-pce",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.beetle-pce",
            "commit": "c50a753e16579816cd335244e6413343a8f292c6"
        }
    ],
    "modules": [
        {
            "name": "libretro-beetle-pce",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app HAVE_CDROM=1",
                "install -D -m 755 mednafen_pce_libretro.so /app/lib/libretro/mednafen_pce_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/libretro/beetle-pce-libretro",
                    "commit": "ae99235c2139c176c1a8d0fde2957bf701d3cab0"
                }
            ]
        }
    ]
}
