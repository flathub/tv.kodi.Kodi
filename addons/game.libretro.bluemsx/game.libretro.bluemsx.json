{
    "name": "game.libretro.bluemsx",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.bluemsx",
            "commit": "27efeb610028c8d22cf7235d6cd1a76c35862da7"
        }
    ],
    "modules": [
        {
            "name": "libretro-bluemsx",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app -f Makefile.libretro",
                "install -D -m 755 bluemsx_libretro.so /app/lib/libretro/bluemsx_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/libretro/blueMSX-libretro/archive/0b23b79f6b8c19f300d2d86958e89fbe2f6d30bc.tar.gz",
                    "sha256": "fbfc3a42fa9f689df1c45cb2cae529af62612bea79e397dfb1bb27dc85e7b085"
                }
            ]
        }
    ]
}
