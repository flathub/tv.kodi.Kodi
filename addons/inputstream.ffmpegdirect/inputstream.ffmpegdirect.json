{
    "name": "inputstream.ffmpegdirect",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/xbmc/inputstream.ffmpegdirect",
            "commit": "3a3a626124ad42d4dbb28a801a17116775fba11e"
        },
        {
            "type": "file",
            "path": "../../tools/gen-addon-metainfo.sh"
        }
    ],
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DPACKAGE_ZIP=ON",
        "-DCMAKE_PREFIX_PATH=/app",
        "-DCMAKE_INSTALL_PREFIX=/app/lib/kodi/addons"
    ],
    "post-install": [
        "bash $FLATPAK_BUILDER_BUILDDIR/gen-addon-metainfo.sh inputstream.ffmpegdirect"
    ]
}
