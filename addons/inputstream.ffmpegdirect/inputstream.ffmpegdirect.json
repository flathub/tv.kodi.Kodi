{
    "name": "inputstream.ffmpegdirect",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/xbmc/inputstream.ffmpegdirect",
            "commit": "527a71baa23a81e79b7ee2b1a658e73b54339978"
        },
        {
            "type": "file",
            "path": "tv.kodi.Kodi.Addon.inputstream.ffmpegdirect.metainfo.xml"
        }
    ],
    "post-install": [
        "install -Dp -m 644 tv.kodi.Kodi.Addon.inputstream.ffmpegdirect.metainfo.xml --target-directory=${FLATPAK_DEST}/share/metainfo"
