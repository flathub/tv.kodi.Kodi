{
    "name": "game.libretro.tgbdual",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.tgbdual",
            "commit": "7b0052d4ad8b2400976f8b60b9bc27f536a9efa8"
        }
    ],
    "modules": [
        {
            "name": "libretro-tgbdual",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app",
                "install -D -m 755 tgbdual_libretro.so /app/lib/libretro/tgbdual_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/libretro/tgbdual-libretro",
                    "commit": "bf816b096f1dca55ea805337d7c9e78d6b98d839"
                }
            ]
        }
    ]
}
