{
    "name": "vfs.sftp",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/xbmc/vfs.sftp",
            "commit": "fbd4351742a0b6a91bc084225b0540fd6fc9f83f"
        }
    ],
    "modules": [
        {
            "name": "libssh",
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "config-opts": [
                "-DWITH_SERVER=OFF",
                "-DWITH_GCRYPT=OFF",
                "-DWITH_EXAMPLES=OFF",
                "-DWITH_GSSAPI=OFF",
                "-DWITH_GEX=OFF",
                "-DCMAKE_BUILD_TYPE=Release"
            ],
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "sources": [
                {
                    "type": "archive",
                    "url": "https://git.libssh.org/projects/libssh.git/snapshot/libssh-0.12.0.tar.gz",
                    "sha256": "a93c97f539f23a213734fa4a1807c7da577ad155d78145d44fd2af26bfb0e2ea",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 1729,
                        "url-template": "https://git.libssh.org/projects/libssh.git/snapshot/libssh-$version.tar.gz"
                    }
                }
            ]
        }
    ],
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ]
}
