{
    "name": "vfs.sftp",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/xbmc/vfs.sftp",
            "commit": "39131bad0505e14d694bd41f01455326b51287c7"
        },
        {
            "type": "file",
            "path": "tv.kodi.Kodi.Addon.vfs.sftp.metainfo.xml"
        }
    ],
    "post-install": [
        "install -Dp -m 644 tv.kodi.Kodi.Addon.vfs.sftp.metainfo.xml --target-directory=${FLATPAK_DEST}/share/metainfo"
    ],
    "modules": [
        {
            "name": "libssh",
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "config-opts": [
                "-DWITH_SERVER=OFF",
                "-DWITH_GCRYPT=OFF",
                "-DWITH_EXAMPLES=OFF",
                "-DWITH_GSSAPI=OFF",
                "-DWITH_GEX=OFF",
                "-DCMAKE_BUILD_TYPE=Release"
            ],
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "sources": [
                {
                    "type": "git",
                    "url": "https://git.libssh.org/projects/libssh.git/",
                    "tag": "libssh-0.12.0",
                    "commit": "50313883f3a077458cde4ea95bf46bfeb0771b34"
                }
            ]
        }
    ],
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DPACKAGE_ZIP=ON"
    ]
}
