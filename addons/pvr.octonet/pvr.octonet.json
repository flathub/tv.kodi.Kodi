{
    "name": "pvr.octonet",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/DigitalDevices/pvr.octonet",
            "commit": "69a637326d548bfea3d79d0a30e5fc409f21564d"
        },
        {
            "type": "file",
            "path": "tv.kodi.Kodi.Addon.pvr.octonet.metainfo.xml"
        }
    ],
    "post-install": [
        "install -Dp -m 644 tv.kodi.Kodi.Addon.pvr.octonet.metainfo.xml --target-directory=${FLATPAK_DEST}/share/metainfo"
    ],
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DPACKAGE_ZIP=ON"
    ]
}
