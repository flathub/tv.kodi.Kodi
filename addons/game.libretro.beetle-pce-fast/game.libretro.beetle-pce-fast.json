            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/libretro/beetle-pce-fast-libretro/archive/9ba79648d6ec85e833aef719d7f359117498d89c.tar.gz",
                    "sha256": "b31d2f4ed7245eec14f7ba7bbd7604cf4eac1ceea1468b20915b570658759d00"
                }
            ]
        }
    ]
}
