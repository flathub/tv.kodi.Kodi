{
    "name": "game.libretro.mesen-s",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.mesen-s",
            "commit": "be07ad9a6f7a2390dca527f7fb9b98510611cd9d"
        }
    ],
    "modules": [
        {
            "name": "libretro-mesen-s",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app -C Libretro/",
                "install -D -m 755 Libretro/mesen-s_libretro.so /app/lib/libretro/mesen-s_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/libretro/mesen-s",
                    "commit": "1d475abd174d16ecb1fb030961ff26076ab51ee6"
                }
            ]
        }
    ]
}
