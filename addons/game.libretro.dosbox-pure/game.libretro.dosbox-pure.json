{
    "name": "game.libretro.dosbox-pure",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.dosbox-pure",
            "commit": "8af86740259ee8549559d7f8596038023046887e"
        }
    ],
    "modules": [
        {
            "name": "libretro-dosbox-pure",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0 -fPIC",
                "cxxflags": "-g0 -fPIC"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app",
                "install -D -m 755 dosbox_pure_libretro.so /app/lib/libretro/dosbox_pure_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/libretro/dosbox-pure",
                    "commit": "42485508b705e215d161eb581dec1984551fa9c2"
                }
            ]
        }
    ]
}
