{
    "name": "game.libretro.dosbox-pure",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.dosbox-pure",
            "commit": "ba98dff5efa0b3ae24fe4c6ef961e99b5b5d88bf"
        }
    ],
    "modules": [
        {
            "name": "libretro-dosbox-pure",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0 -fPIC",
                "cxxflags": "-g0 -fPIC"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app",
                "install -D -m 755 dosbox_pure_libretro.so /app/lib/libretro/dosbox_pure_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/libretro/dosbox-pure/archive/42485508b705e215d161eb581dec1984551fa9c2.tar.gz",
                    "sha256": "dd8030298b1e04376442d7dd0ac32c13b5804d5ccbc96ad6eb10c604e677e052"
                }
            ]
        }
    ]
}
