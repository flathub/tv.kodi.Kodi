{
    "name": "game.libretro.yabause",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DPACKAGE_ZIP=ON",
        "-DCMAKE_PREFIX_PATH=/app",
        "-DCMAKE_INSTALL_PREFIX=/app/lib/kodi/addons"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.yabause",
            "commit": "1dd72ccec95521761b46118f0a405e986e161032"
        },
        {
            "type": "file",
            "path": "../../tools/gen-addon-metainfo.sh"
        }
    ],
    "modules": [
        {
            "name": "libretro-yabause",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0",
                "arch": {
                    "x86_64": {
                        "env": {
                            "ARCH_FLAGS": "HAVE_SSE=1"
                        }
                    },
                    "aarch64": {
                        "env": {
                            "ARCH_FLAGS": "HAVE_SSE=0"
                        }
                    }
                }
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app $ARCH_FLAGS -C yabause/src/libretro",
                "install -D -m 755 yabause/src/libretro/yabause_libretro.so /app/lib/libretro/yabause_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/libretro/yabause",
                    "commit": "8926b0c6c347f8c5c755911ddb0ac695420ffbf8"
                }
            ]
        }
    ],
    "post-install": [
        "bash $FLATPAK_BUILDER_BUILDDIR/gen-addon-metainfo.sh game.libretro.yabause"
    ]
}
