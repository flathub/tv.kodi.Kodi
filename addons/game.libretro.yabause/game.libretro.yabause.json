{
    "name": "game.libretro.yabause",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.yabause",
            "commit": "b9599fcc0c00a6808d0a84968f93c065db0be48c"
        }
    ],
    "modules": [
        {
            "name": "libretro-yabause",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0",
                "arch": {
                    "x86_64": {
                        "env": {
                            "ARCH_FLAGS": "HAVE_SSE=1"
                        }
                    },
                    "aarch64": {
                        "env": {
                            "ARCH_FLAGS": "HAVE_SSE=0"
                        }
                    }
                }
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app $ARCH_FLAGS -C yabause/src/libretro",
                "install -D -m 755 yabause/src/libretro/yabause_libretro.so /app/lib/libretro/yabause_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/libretro/yabause/archive/7cb15b8f9eea5a6fa7cae34468a6989522bcba75.tar.gz",
                    "sha256": "4c9b818067b333583c640ac7eb395adc47f480ede4e32f94e11b2d45e2bb26be"
                }
            ]
        }
    ]
}
