{
    "name": "game.libretro.beetle-vb",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.beetle-vb",
            "commit": "ef7584ab012470612bda51ff73e31f3b024df0de"
        }
    ],
    "modules": [
        {
            "name": "libretro-beetle-vb",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app",
                "install -D -m 755 mednafen_vb_libretro.so /app/lib/libretro/mednafen_vb_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/libretro/beetle-vb-libretro",
                    "commit": "38e7a0ec9ac7079ca1c1e3dd9aaf5b56f527efca"
                }
            ]
        }
    ]
}
