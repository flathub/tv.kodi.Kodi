{
    "name": "game.libretro.beetle-vb",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.beetle-vb",
            "commit": "2837516b251501047cbaf1d51152fc20e5e1479b"
        }
    ],
    "modules": [
        {
            "name": "libretro-beetle-vb",
