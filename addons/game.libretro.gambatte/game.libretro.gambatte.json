{
    "name": "game.libretro.gambatte",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.gambatte",
            "commit": "db4ec48c2ab997c9d34aa437ee6ec2baa6760e0a"
        }
    ],
    "modules": [
        {
            "name": "libretro-gambatte",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app -f Makefile.libretro",
                "install -D -m 755 gambatte_libretro.so /app/lib/libretro/gambatte_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/libretro/gambatte-libretro",
                    "commit": "3262c2aa4adae8dba4f6d51cdd931c15cb11569f"
                }
            ]
        }
    ]
}
