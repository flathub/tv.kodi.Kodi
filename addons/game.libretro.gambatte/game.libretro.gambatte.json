{
    "name": "game.libretro.gambatte",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.gambatte",
            "commit": "d5a3f34429066143e6b9f7114115f5afae8cd3ba"
        }
    ],
    "modules": [
        {
            "name": "libretro-gambatte",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app -f Makefile.libretro",
                "install -D -m 755 gambatte_libretro.so /app/lib/libretro/gambatte_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/libretro/gambatte-libretro",
                    "commit": "dfc165599f3f1068c40a0b7ad6fe5f161283d483"
                }
            ]
        }
    ]
}
