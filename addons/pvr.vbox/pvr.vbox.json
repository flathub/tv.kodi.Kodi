{
    "name": "pvr.vbox",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-pvr/pvr.vbox",
            "commit": "2ee26e6a83293e9ad1c545e33b25ef08eaecd24c"
        },
        {
            "type": "file",
            "path": "tv.kodi.Kodi.Addon.pvr.vbox.metainfo.xml"
        }
    ],
    "post-install": [
        "install -Dp -m 644 tv.kodi.Kodi.Addon.pvr.vbox.metainfo.xml --target-directory=${FLATPAK_DEST}/share/metainfo"
    ],
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DPACKAGE_ZIP=ON"
    ]
}
