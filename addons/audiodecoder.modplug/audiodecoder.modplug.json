{
    "name": "audiodecoder.modplug",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/xbmc/audiodecoder.modplug",
            "commit": "4e6f113d70d578f2d15a339966d7d5f9e848abbc"
        },
        {
            "type": "file",
            "path": "tv.kodi.Kodi.Addon.audiodecoder.modplug.metainfo.xml"
        }
    ],
    "post-install": [
        "install -Dp -m 644 tv.kodi.Kodi.Addon.audiodecoder.modplug.metainfo.xml --target-directory=${FLATPAK_DEST}/share/metainfo"
    ],
    "modules": [
        {
            "name": "libmodplug",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DBUILD_SHARED_LIBS=ON",
                "-DCMAKE_BUILD_TYPE=Release"
            ],
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/Konstanty/libmodplug.git",
                    "commit": "d1b97ed0020bc620a059d3675d1854b40bd2608d"
                },
                {
                    "type": "patch",
                    "path": "patches/libmodplug-fix-cmake.patch"
                }
            ]
        }
    ],
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DPACKAGE_ZIP=ON"
    ]
}
