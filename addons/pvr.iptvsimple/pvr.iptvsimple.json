{
    "name": "pvr.iptvsimple",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-pvr/pvr.iptvsimple",
            "commit": "739177cad2de291a70175b76e79f0ce16688c0da"
        },
        {
            "type": "file",
            "path": "tv.kodi.Kodi.Addon.pvr.iptvsimple.metainfo.xml"
        }
    ],
    "post-install": [
        "install -Dp -m 644 tv.kodi.Kodi.Addon.pvr.iptvsimple.metainfo.xml --target-directory=${FLATPAK_DEST}/share/metainfo"
    ],
    "build-options": {
        "no-debuginfo": true,
        "cxxflags": "-g0 -Wp,-U_GLIBCXX_ASSERTIONS",
        "cflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DPACKAGE_ZIP=ON"
    ]
}
