{
    "name": "game.shader.presets",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DPACKAGE_ZIP=ON"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.shader.presets",
            "commit": "f94f0505014b889f93b5583c74d273dee5795b7b"
        },
        {
            "type": "file",
            "path": "tv.kodi.Kodi.Addon.game.shader.presets.metainfo.xml"
        }
    ],
    "post-install": [
        "install -Dp -m 644 tv.kodi.Kodi.Addon.game.shader.presets.metainfo.xml --target-directory=${FLATPAK_DEST}/share/metainfo"
    ]
}
