{
    "name": "audioencoder.wav",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/xbmc/audioencoder.wav",
            "commit": "16335df698abcb3dbc00ca225fd1ac31b7bf62ab"
        },
        {
            "type": "file",
            "path": "tv.kodi.Kodi.Addon.audioencoder.wav.metainfo.xml"
