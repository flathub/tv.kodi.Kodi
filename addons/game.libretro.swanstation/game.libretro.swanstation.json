{
    "name": "game.libretro.swanstation",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DPACKAGE_ZIP=ON",
        "-DCMAKE_PREFIX_PATH=/app",
        "-DCMAKE_INSTALL_PREFIX=/app/lib/kodi/addons"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.swanstation",
            "commit": "17e8a9b6422e2d851aae1fe16b1c007bc7cc33d3"
        },
        {
            "type": "file",
            "path": "../../tools/gen-addon-metainfo.sh"
        }
    ],
    "modules": [
        {
            "name": "libretro-swanstation",
            "buildsystem": "cmake-ninja",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "config-opts": [
                "-DCMAKE_BUILD_TYPE=Release"
            ],
            "no-make-install": true,
            "post-install": [
                "install -D -m 755 swanstation_libretro.so /app/lib/libretro/swanstation_libretro.so"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/libretro/swanstation",
                    "commit": "f901022198dacf125d43331c6540492441ab415b"
                }
            ]
        }
    ],
    "post-install": [
        "bash $FLATPAK_BUILDER_BUILDDIR/gen-addon-metainfo.sh game.libretro.swanstation"
    ]
}
