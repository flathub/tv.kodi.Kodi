{
    "name": "visualization.shadertoy",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/xbmc/visualization.shadertoy",
            "commit": "f310bea8e606ff7fdb7053b2ce0eed7e2a12664d"
        },
        {
            "type": "file",
            "path": "tv.kodi.Kodi.Addon.visualization.shadertoy.metainfo.xml"
        }
    ],
    "post-install": [
        "install -Dp -m 644 tv.kodi.Kodi.Addon.visualization.shadertoy.metainfo.xml --target-directory=${FLATPAK_DEST}/share/metainfo"
    ],
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DPACKAGE_ZIP=ON"
    ]
}
