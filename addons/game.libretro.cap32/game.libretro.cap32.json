{
    "name": "game.libretro.cap32",
    "buildsystem": "cmake-ninja",
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/kodi-game/game.libretro.cap32",
            "commit": "c61501d0ef9f398fcb22018a79fe09d52f893294"
        }
    ],
    "modules": [
        {
            "name": "libretro-cap32",
            "buildsystem": "simple",
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "build-commands": [
                "make -j$FLATPAK_BUILDER_N_JOBS PREFIX=/app",
                "install -D -m 755 cap32_libretro.so /app/lib/libretro/cap32_libretro.so"
            ],
            "cleanup": [
                "/lib/libretro"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/libretro/libretro-cap32/archive/4abfb8be233bec630f369379fb6c1d92d31f1c7d.tar.gz",
                    "sha256": "45c92ca63aaf2d12c81b9c1de28b0a301b1c37c5b5de7fcfd44fe303c45662b9"
                }
            ]
        }
    ]
}
