{
    "name": "visualization.projectm",
    "buildsystem": "cmake-ninja",
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/xbmc/visualization.projectm",
            "commit": "a88737a3e978a5be41fe322febe56b6141d355f5"
        }
    ],
    "modules": [
        {
            "name": "projectm-eval",
            "buildsystem": "cmake-ninja",
            "cleanup": [
                "/include",
                "/lib/cmake",
                "/lib/pkgconfig",
                "*.a"
            ],
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "config-opts": [
                "-DCMAKE_BUILD_TYPE=Release",
                "-DENABLE_PROJECTM_EVAL_INSTALL=ON"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/projectM-visualizer/projectm-eval",
                    "commit": "da885dcdf33620ef26aa04cac9e215378b80252e",
                    "x-checker-data": {
                        "type": "git",
                        "tag-pattern": "^v([\\d.]+)$"
                    },
                    "tag": "v1.0.6"
                }
            ]
        },
        {
            "name": "projectm",
            "buildsystem": "cmake-ninja",
            "cleanup": [
                "/bin"
            ],
            "build-options": {
                "no-debuginfo": true,
                "cflags": "-g0",
                "cxxflags": "-g0"
            },
            "config-opts": [
                "-DCMAKE_BUILD_TYPE=Release",
                "-DENABLE_SYSTEM_PROJECTM_EVAL=ON",
                "-DENABLE_GLES=ON"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/projectM-visualizer/projectm",
                    "commit": "e0b0a967f0ffd7d332106c366668ed271718472b",
                    "disable-submodules": true,
                    "x-checker-data": {
                        "type": "git",
                        "tag-pattern": "^v([\\d.]+)$"
                    },
                    "tag": "v4.1.7"
                }
            ]
        }
    ],
    "build-options": {
        "no-debuginfo": true,
        "cflags": "-g0",
        "cxxflags": "-g0"
    },
    "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release"
    ]
}
